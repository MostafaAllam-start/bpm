# API base the app appends paths like /Account/login to — see src/auth/api.ts.
#
# In dev we use a RELATIVE base so calls stay same-origin and go through Vite's
# `/api` proxy (see vite.config.ts), which forwards them to api.ecmplus.org
# server-side and sidesteps CORS. For a direct cross-origin build instead, set
# this to https://api.ecmplus.org/api — but then the API must return CORS
# headers (Access-Control-Allow-Origin) for the site's origin.
VITE_API_BASE=/api
